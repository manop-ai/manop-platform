      if (dir===1) { setPh(word.slice(0,ci+1)); ci++; if (ci>=word.length){dir=-1;paused=true} }
      else { setPh(word.slice(0,ci-1)); ci--; if (ci<=7){dir=1;i=(i+1)%ex.length} }
    }
    const id = setInterval(tick, 70)
    return () => clearInterval(id)
  }, [])

