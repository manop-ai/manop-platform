                        </div>
                      </div>
                      <div style={{ display: 'flex', gap: 6, flexShrink: 0, flexWrap: 'wrap' as const }}>
                        <Link href={`/property/${l.id}`} target="_blank" style={{ fontSize: 11, color: '#14B8A6', border: '1px solid rgba(20,184,166,0.3)', padding: '3px 8px', borderRadius: 6, textDecoration: 'none' }}>View ↗</Link>
                        <button onClick={() => { setEditId(isEditing ? null : l.id); setEditPrice('') }} style={{ fontSize: 11, color: isEditing ? '#F59E0B' : text3, border: `1px solid ${isEditing ? 'rgba(245,158,11,0.4)' : border}`, padding: '3px 8px', borderRadius: 6, background: 'transparent', cursor: 'pointer' }}>
