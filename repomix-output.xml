// ─── Title Document Normalizer ────────────────────────────────────────────

const TITLE_TYPES: Record<string, string> = {
  'c of o': 'C of O',
  'cofo': 'C of O',
  'c.o.f.o': 'C of O',
  'certificate of occupancy': 'C of O',
  "governor's consent": "Governor's Consent",
  'governors consent': "Governor's Consent",
