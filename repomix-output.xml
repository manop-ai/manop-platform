            {rows.map((row, i) => {
              const isLast = i === rows.length - 1
              const aWins  = row.winner === 'a'
              const bWins  = row.winner === 'b'

              return (
                <div key={row.metric} style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '1px', marginBottom: '1px' }}>
