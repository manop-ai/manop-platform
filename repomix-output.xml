          </div>
        )}

        <div style={{ marginTop: '1.5rem', fontSize: '0.72rem', color: text3 }}>
          Need help? <a href="mailto:partners@manopintel.com" style={{ color: '#14B8A6' }}>partners@manopintel.com</a>
        </div>
      </div>
    </div>
  )
}
