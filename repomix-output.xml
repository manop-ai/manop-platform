            <div style={{ display:'flex', alignItems:'center', gap:'0.5rem', fontSize:'0.7rem', fontWeight:700, color:'#14B8A6', textTransform:'uppercase', letterSpacing:'0.15em', marginBottom:'0.5rem' }}>
