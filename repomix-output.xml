                <div>
                  <label style={{ fontSize: '0.68rem', color: text2, marginBottom: '0.3rem', display: 'block', fontWeight: 500 }}>Contact email</label>
                  <input style={INP} defaultValue={partner.contact_email || ''} />
                </div>
