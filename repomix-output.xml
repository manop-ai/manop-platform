/* ── Manop Brand System ───────────────────────────────────────────────────── */
:root {
  /* Brand Colors */
  --purple:       #5B2EFF;
  --purple-light: #7C5FFF;
  --purple-dim:   #3D1FCC;
  --lavender:     #A78BFA;
  --lavender-dim: #7C66C4;
  --teal:         #14B8A6;
  --teal-light:   #2DD4BF;
  --teal-dim:     #0D9488;

  /* Backgrounds */
  --navy:         #0F172A;
  --navy-mid:     #1E293B;
  --navy-soft:    #273549;
  --navy-card:    #162032;

  /* Text */
  --white:        #FFFFFF;
  --white-muted:  rgba(255,255,255,0.65);
  --white-dim:    rgba(255,255,255,0.35);

  /* Semantic */
  --green:        #10B981;
  --amber:        #F59E0B;
  --red:          #EF4444;

  /* Borders */
  --border:       rgba(91,46,255,0.2);
  --border-light: rgba(255,255,255,0.07);
  --border-teal:  rgba(20,184,166,0.25);

  /* Typography */
  --font-display: 'Inter', -apple-system, sans-serif;
  --font-body:    'Inter', -apple-system, sans-serif;
  --font-mono:    'JetBrains Mono', 'Fira Code', monospace;
}

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--navy);
  color: var(--white);
  font-size: 16px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

a { color: inherit; text-decoration: none; }
button { cursor: pointer; font-family: var(--font-body); }

/* ── NAV ── */
.nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(15,23,42,0.88);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border-light);
  padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between;
  height: 68px;
}

.nav-brand {
  display: flex; align-items: center; gap: 0.6rem;
}

.nav-logo-z {
  width: 36px; height: 36px;
  background: var(--purple);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}

.nav-logo-z::after {
  content: 'Z';
  font-size: 1.1rem; font-weight: 700;
  color: white; letter-spacing: -0.02em;
}

.nav-brand-name {
  font-size: 1.1rem; font-weight: 700;
  color: var(--white); letter-spacing: -0.02em;
}

.nav-brand-sub {
  font-size: 0.6rem; font-weight: 400;
  color: var(--teal); letter-spacing: 0.12em;
  text-transform: uppercase;
  display: block; margin-top: -2px;
}

.nav-links {
  display: flex; gap: 0.25rem; list-style: none; align-items: center;
}

.nav-links a {
  font-size: 0.85rem; font-weight: 500;
  color: var(--white-muted);
  padding: 0.45rem 0.875rem;
  border-radius: 6px;
  transition: all 0.15s;
}

.nav-links a:hover { color: var(--white); background: rgba(255,255,255,0.06); }

.nav-cta {
  background: var(--purple) !important;
  color: var(--white) !important;
  padding: 0.45rem 1rem !important;
  border-radius: 8px !important;
  font-weight: 600 !important;
  font-size: 0.82rem !important;
  transition: background 0.15s !important;
}

.nav-cta:hover { background: var(--purple-light) !important; }

/* ── HERO ── */
.hero {
  position: relative; overflow: hidden;
  padding: 7rem 2rem 6rem;
  background: var(--navy);
}

.hero-glow {
