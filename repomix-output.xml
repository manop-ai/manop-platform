        <div style={{ position:'absolute', top:9, left:9, background:`${typeColor}ee`, color:'#fff', borderRadius:5, padding:'0.15rem 0.45rem', fontSize:'0.6rem', fontWeight:700, textTransform:'uppercase', letterSpacing:'0.06em' }}>
