// ─── Property Type Normalizer ─────────────────────────────────────────────

const PROPERTY_TYPES: Record<string, string> = {
  'detached duplex': 'Detached Duplex',
  'semi detached duplex': 'Semi-Detached Duplex',
  'semi-detached duplex': 'Semi-Detached Duplex',
  'terraced duplex': 'Terraced Duplex',
