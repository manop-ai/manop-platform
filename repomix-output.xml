  const border  = v('rgba(248,250,252,0.07)','rgba(15,23,42,0.08)')

  return (
    <div style={{ background:bg, minHeight:'100vh', color:text, transition:'background 0.3s, color 0.3s' }}>

      {/* ── HERO ── */}
